{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server",
    "push": "npm run clean && npm run build && npm run deploy",
    "preview": "hexo server --open",
    "new:post": "powershell -ExecutionPolicy Bypass .\\blog-tool.ps1 new",
    "sync": "powershell -ExecutionPolicy Bypass .\\blog-tool.ps1 sync",
    "list": "powershell -ExecutionPolicy Bypass .\\blog-tool.ps1 list",
    "blog": "powershell -ExecutionPolicy Bypass .\\blog-tool.ps1"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
    "hexo": "^7.0.0",
    "hexo-deployer-git": "^4.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^6.0.0",
    "hexo-renderer-stylus": "^3.0.0",
    "hexo-server": "^3.0.0",
    "hexo-theme-landscape": "^1.0.0",
    "hexo-theme-next": "^8.28.0"
  }
}